<archetype-descriptor
    xmlns="http://apache.org"
    name="dominio-archetype">

    <requiredProperties>
        <requiredProperty key="parentArtifactId" />
        <requiredProperty key="domainClassName" />
    </requiredProperties>

    <fileSets>
        <!-- Código Java Principal -->
        <fileSet filtered="true" packaged="true" encoding="UTF-8">
            <directory>src/main/java</directory>
            <includes>
                <include>**/*.java</include>
            </includes>
        </fileSet>

        <!-- Definições de gRPC (Proto) -->
        <fileSet filtered="true" encoding="UTF-8">
            <directory>src/main/proto</directory>
            <includes>
                <include>**/*.proto</include>
            </includes>
        </fileSet>

        <!-- Recursos (microprofile-config.properties) "application.properties específicas do
        módulo" -->
        <fileSet filtered="true" encoding="UTF-8">
            <directory>src/main/resources/META-INF</directory>
            <includes>
                <include>microprofile-config.properties</include>
            </includes>
        </fileSet>

        <!-- Testes -->
        <fileSet filtered="true" packaged="true" encoding="UTF-8">
            <directory>src/test/java</directory>
            <includes>
                <include>**/*.java</include>
            </includes>
        </fileSet>

        <!-- POM do Módulo -->
        <fileSet filtered="true" encoding="UTF-8">
            <directory></directory>
            <includes>
                <include>pom.xml</include>
            </includes>
        </fileSet>
    </fileSets>
</archetype-descriptor>